<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Rule to rewrite all requests to the public directory -->
                <rule name="Rewrite to public folder" stopProcessing="true">
                    <match url="^(.*)$" />
                    <conditions>
                        <!-- Negate rewriting if request is already for public/ folder -->
                        <add input="{REQUEST_URI}" pattern="^/public/" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
