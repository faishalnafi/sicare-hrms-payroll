{
    "name": "sicare/app",
    "description": "siCare - Custom MVC Framework PHP 8.3",
    "type": "project",
    "require": {
        "php": ">=8.3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
